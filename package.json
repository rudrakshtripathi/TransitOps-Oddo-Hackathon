{
  "name": "transit-ops",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "prettier --check .",
    "format": "prettier --write .",
    "db:push": "bun --env-file=.env drizzle-kit push",
    "db:generate": "bun --env-file=.env drizzle-kit generate",
    "db:migrate": "bun --env-file=.env drizzle-kit migrate",
    "db:studio": "bun --env-file=.env drizzle-kit studio",
    "db:seed": "bun --env-file=.env src/lib/server/db/seed/seed.ts"
  },
  "devDependencies": {
    "@fontsource-variable/nunito-sans": "^5.2.7",
    "@fontsource-variable/source-sans-3": "^5.2.9",
    "@internationalized/date": "^3.12.0",
    "@lucide/svelte": "^1.24.0",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.63.0",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/table-core": "^8.21.3",
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.1",
    "bits-ui": "^2.16.3",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "layerchart": "^2.0.1",
    "postgres": "^3.4.9",
    "prettier": "^3.8.3",
    "prettier-plugin-svelte": "^4.1.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "shadcn-svelte": "^1.4.1",
    "svelte": "^5.56.1",
    "svelte-check": "^4.6.0",
    "svelte-sonner": "^1.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "dependencies": {
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.2",
    "mode-watcher": "^1.1.0",
    "valibot": "^1.4.2"
  }
}
