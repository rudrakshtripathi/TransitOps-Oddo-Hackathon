<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_maintenance_form" model="ir.ui.view">
        <field name="name">transitops.maintenance.form</field>
        <field name="model">transitops.maintenance</field>
        <field name="arch" type="xml">
            <form string="Maintenance Record">
                <header>
                    <button name="action_close" string="Mark as Closed" type="object"
                            class="btn-primary"
                            invisible="state == 'closed'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="open,closed"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="vehicle_id"/>
                            <field name="date_logged"/>
                            <field name="cost" widget="monetary"/>
                        </group>
                        <group>
                            <field name="state"/>
                        </group>
                    </group>
                    <group string="Description">
                        <field name="description" nolabel="1"
                               placeholder="Describe the maintenance work..."/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_maintenance_tree" model="ir.ui.view">
        <field name="name">transitops.maintenance.tree</field>
        <field name="model">transitops.maintenance</field>
        <field name="arch" type="xml">
            <tree string="Maintenance Records">
                <field name="vehicle_id"/>
                <field name="description"/>
                <field name="cost" widget="monetary"/>
                <field name="state" widget="badge"
                       decoration-warning="state == 'open'"
                       decoration-success="state == 'closed'"/>
                <field name="date_logged"/>
            </tree>
        </field>
    </record>

    <record id="view_maintenance_search" model="ir.ui.view">
        <field name="name">transitops.maintenance.search</field>
        <field name="model">transitops.maintenance</field>
        <field name="arch" type="xml">
            <search string="Search Maintenance">
                <field name="vehicle_id"/>
                <filter string="Open" name="filter_open" domain="[('state','=','open')]"/>
                <filter string="Closed" name="filter_closed" domain="[('state','=','closed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Vehicle" name="group_vehicle" context="{'group_by':'vehicle_id'}"/>
                    <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
