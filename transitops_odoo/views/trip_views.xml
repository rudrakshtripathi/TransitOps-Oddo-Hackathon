<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_trip_form" model="ir.ui.view">
        <field name="name">transitops.trip.form</field>
        <field name="model">transitops.trip</field>
        <field name="arch" type="xml">
            <form string="Trip">
                <header>
                    <button name="action_dispatch" string="Dispatch" type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_complete" string="Complete" type="object"
                            class="btn-success"
                            invisible="state != 'dispatched'"/>
                    <button name="action_cancel" string="Cancel" type="object"
                            class="btn-danger"
                            invisible="state not in ['draft', 'dispatched']"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,dispatched,completed,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Route">
                            <field name="source"/>
                            <field name="destination"/>
                            <field name="planned_distance"/>
                            <field name="cargo_weight"/>
                        </group>
                        <group string="Assignment">
                            <field name="vehicle_id"
                                   options='{"no_create": true, "no_quick_create": true}'/>
                            <field name="driver_id"
                                   options='{"no_create": true, "no_quick_create": true}'/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_trip_tree" model="ir.ui.view">
        <field name="name">transitops.trip.tree</field>
        <field name="model">transitops.trip</field>
        <field name="arch" type="xml">
            <tree string="Trips">
                <field name="name" string="Route"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <field name="cargo_weight"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'dispatched'"
                       decoration-success="state == 'completed'"
                       decoration-danger="state == 'cancelled'"/>
                <field name="create_date" string="Created At"/>
            </tree>
        </field>
    </record>

    <record id="view_trip_kanban" model="ir.ui.view">
        <field name="name">transitops.trip.kanban</field>
        <field name="model">transitops.trip</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="state"/>
                <field name="driver_id"/>
                <field name="vehicle_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <span t-attf-class="badge rounded-pill
                                    #{record.state.raw_value == 'draft' ? 'text-bg-secondary' :
                                      record.state.raw_value == 'dispatched' ? 'text-bg-warning' :
                                      record.state.raw_value == 'completed' ? 'text-bg-success' : 'text-bg-danger'}">
                                    <field name="state"/>
                                </span>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><i class="fa fa-user"/> <field name="driver_id"/></div>
                                <div><i class="fa fa-truck"/> <field name="vehicle_id"/></div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_trip_search" model="ir.ui.view">
        <field name="name">transitops.trip.search</field>
        <field name="model">transitops.trip</field>
        <field name="arch" type="xml">
            <search string="Search Trips">
                <field name="name"/>
                <field name="vehicle_id"/>
                <field name="driver_id"/>
                <filter string="Draft" name="filter_draft" domain="[('state','=','draft')]"/>
                <filter string="Dispatched" name="filter_dispatched" domain="[('state','=','dispatched')]"/>
                <filter string="Completed" name="filter_completed" domain="[('state','=','completed')]"/>
                <group expand="0" string="Group By">
                    <filter string="Status" name="group_state" context="{'group_by':'state'}"/>
                    <filter string="Vehicle" name="group_vehicle" context="{'group_by':'vehicle_id'}"/>
                    <filter string="Driver" name="group_driver" context="{'group_by':'driver_id'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
