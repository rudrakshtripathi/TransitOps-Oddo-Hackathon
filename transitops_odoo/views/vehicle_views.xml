<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_vehicle_tree" model="ir.ui.view">
        <field name="name">transitops.vehicle.tree</field>
        <field name="model">transitops.vehicle</field>
        <field name="arch" type="xml">
            <tree string="Vehicles"
                  decoration-success="state == 'available'"
                  decoration-danger="state == 'in_shop'"
                  decoration-muted="state == 'retired'"
                  decoration-warning="state == 'on_trip'">
                <field name="name" string="Registration"/>
                <field name="model"/>
                <field name="vehicle_type"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'available'"
                       decoration-danger="state == 'in_shop'"
                       decoration-warning="state == 'on_trip'"
                       decoration-secondary="state == 'retired'"/>
                <field name="odometer" string="Odometer (km)"/>
                <field name="fuel_efficiency" string="Efficiency (km/L)" digits="[16,2]"/>
            </tree>
        </field>
    </record>

    <record id="view_vehicle_form" model="ir.ui.view">
        <field name="name">transitops.vehicle.form</field>
        <field name="model">transitops.vehicle</field>
        <field name="arch" type="xml">
            <form string="Vehicle">
                <header>
                    <field name="state" widget="statusbar"
                           statusbar_visible="available,on_trip,in_shop,retired"
                           clickable="1"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_maintenance)d" type="action"
                                class="oe_stat_button" icon="fa-wrench">
                            <field name="maintenance_ids" widget="statinfo"
                                   string="Maintenance"/>
                        </button>
                        <button name="%(action_fuel_logs)d" type="action"
                                class="oe_stat_button" icon="fa-tint">
                            <field name="fuel_log_ids" widget="statinfo"
                                   string="Fuel Logs"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Registration Number"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Vehicle Details">
                            <field name="name" string="Registration Number"/>
                            <field name="model"/>
                            <field name="vehicle_type"/>
                            <field name="max_capacity"/>
                            <field name="odometer"/>
                        </group>
                        <group string="Financial">
                            <field name="acquisition_cost" widget="monetary"/>
                            <field name="total_operational_cost" widget="monetary" readonly="1"/>
                            <field name="total_fuel_cost" widget="monetary" readonly="1"/>
                            <field name="total_maintenance_cost" widget="monetary" readonly="1"/>
                            <field name="fuel_efficiency" readonly="1"/>
                            <field name="roi_percentage" readonly="1" string="ROI %"/>
                        </group>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="view_vehicle_kanban" model="ir.ui.view">
        <field name="name">transitops.vehicle.kanban</field>
        <field name="model">transitops.vehicle</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_small_column">
                <field name="name"/>
                <field name="vehicle_type"/>
                <field name="state"/>
                <field name="odometer"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_record_top">
                                <div class="o_kanban_record_headings">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <span t-attf-class="badge rounded-pill
                                    #{record.state.raw_value == 'available' ? 'text-bg-success' :
                                      record.state.raw_value == 'on_trip' ? 'text-bg-warning' :
                                      record.state.raw_value == 'in_shop' ? 'text-bg-danger' : 'text-bg-secondary'}">
                                    <field name="state"/>
                                </span>
                            </div>
                            <div class="o_kanban_record_body">
                                <div><i class="fa fa-tag"/> <field name="vehicle_type"/></div>
                                <div><i class="fa fa-tachometer"/> <field name="odometer"/> km</div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_vehicle_search" model="ir.ui.view">
        <field name="name">transitops.vehicle.search</field>
        <field name="model">transitops.vehicle</field>
        <field name="arch" type="xml">
            <search string="Search Vehicles">
                <field name="name" string="Registration"/>
                <field name="model"/>
                <filter string="Available" name="filter_available"
                        domain="[('state','=','available')]"/>
                <filter string="In Maintenance" name="filter_in_shop"
                        domain="[('state','=','in_shop')]"/>
                <filter string="On Trip" name="filter_on_trip"
                        domain="[('state','=','on_trip')]"/>
                <group expand="0" string="Group By">
                    <filter string="Type" name="group_vehicle_type"
                            context="{'group_by':'vehicle_type'}"/>
                    <filter string="Status" name="group_state"
                            context="{'group_by':'state'}"/>
                </group>
            </search>
        </field>
    </record>

</odoo>
