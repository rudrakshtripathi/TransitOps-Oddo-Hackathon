<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_report_trip_manifest" model="ir.actions.report">
        <field name="name">Trip Manifest</field>
        <field name="model">transitops.trip</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">transitops.report_trip_manifest</field>
        <field name="report_file">transitops.report_trip_manifest</field>
        <field name="binding_model_id" ref="model_transitops_trip"/>
        <field name="binding_type">report</field>
    </record>

    <template id="report_trip_manifest">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="trip">
                <t t-call="web.external_layout">
                    <div class="page">
                        <h2>Trip Manifest</h2>
                        <h3 t-field="trip.name"/>
                        <div class="row mt-4">
                            <div class="col-6">
                                <h4>Route</h4>
                                <table class="table table-sm">
                                    <tr><td><strong>From</strong></td><td t-field="trip.source"/></tr>
                                    <tr><td><strong>To</strong></td><td t-field="trip.destination"/></tr>
                                    <tr><td><strong>Distance</strong></td><td><t t-esc="trip.planned_distance"/> km</td></tr>
                                    <tr><td><strong>Cargo Weight</strong></td><td><t t-esc="trip.cargo_weight"/> kg</td></tr>
                                </table>
                            </div>
                            <div class="col-6">
                                <h4>Driver</h4>
                                <table class="table table-sm">
                                    <tr><td><strong>Name</strong></td><td t-field="trip.driver_id.name"/></tr>
                                    <tr><td><strong>License</strong></td><td t-field="trip.driver_id.license_number"/></tr>
                                    <tr><td><strong>Category</strong></td><td t-field="trip.driver_id.license_category"/></tr>
                                </table>
                            </div>
                        </div>
                        <h4 class="mt-4">Vehicle</h4>
                        <table class="table table-sm">
                            <tr><td><strong>Registration</strong></td><td t-field="trip.vehicle_id.name"/></tr>
                            <tr><td><strong>Type</strong></td><td t-field="trip.vehicle_id.vehicle_type"/></tr>
                            <tr><td><strong>Max Capacity</strong></td><td><t t-esc="trip.vehicle_id.max_capacity"/> kg</td></tr>
                        </table>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
